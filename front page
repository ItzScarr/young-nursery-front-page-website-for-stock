<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Youngs Nursery Stock</title>

    <!-- LINK TO CSS (IMPORTANT) -->
    <link rel="stylesheet" href="style.css">
</head>

<body>

<header>
    <nav>
        <h1>Youngs Nursery</h1>
        <ul>
            <li>Plants</li>
            <li>Seeds</li>
            <li>Garden Care</li>
            <li>Pots</li>
            <li>Contact</li>
        </ul>
    </nav>
</header>

<section class="hero">
    <h2>Welcome to Youngs Nursery</h2>
    <p>Check stock instantly across the store</p>
</section>

<div class="container">

    <h2>Categories</h2>
    <div class="cards">
        <div class="card">Plants</div>
        <div class="card">Houseplants</div>
        <div class="card">Seeds</div>
        <div class="card">Garden Care</div>
    </div>

    <h2>Stock Table</h2>

    <table id="stockTable">
        <thead>
            <tr>
                <th>Item</th>
                <th>Location</th>
                <th>Stock Level</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Rose Plant</td>
                <td>Aisle 3</td>
                <td><span class="stock-high">Above Half</span></td>
            </tr>
            <tr>
                <td>Compost Bag</td>
                <td>Outdoor Yard</td>
                <td><span class="stock-medium">Below Half</span></td>
            </tr>
            <tr>
                <td>Tomato Seeds</td>
                <td>Seed Rack</td>
                <td><span class="stock-low">Out of Stock</span></td>
            </tr>
        </tbody>
    </table>

</div>

<footer>
    <p>&copy; 2026 Youngs Nursery</p>
</footer>

<script>
function addItem(name, location, stock) {
    const table = document.getElementById("stockTable").querySelector("tbody");

    let stockClass = "";
    let stockText = "";

    if (stock === "high") {
        stockClass = "stock-high";
        stockText = "Above Half";
    } else if (stock === "medium") {
        stockClass = "stock-medium";
        stockText = "Below Half";
    } else {
        stockClass = "stock-low";
        stockText = "Out of Stock";
    }

    const row = `
        <tr>
            <td>${name}</td>
            <td>${location}</td>
            <td><span class="${stockClass}">${stockText}</span></td>
        </tr>
    `;

    table.innerHTML += row;
}
</script>

</body>
</html>